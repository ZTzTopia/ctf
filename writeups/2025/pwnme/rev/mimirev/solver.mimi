init vv = 0;
init vvv = 1;
init expr = 0;

while vvv < 314159 {
    if expr == 273262 {
        verifyProof(vvv, vv);
        rea vvv = 1;
        break;
    } else {
        rea vvv = vvv + 1;
        rea vv = 314159 - vvv;
        rea expr = (vvv * vvv + vv * vv * vv - vvv * vv) % 1048573;
    }
}
